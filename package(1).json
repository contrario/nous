{
  "name": "nous-lang",
  "displayName": "NOUS — The Living Language",
  "description": "Syntax highlighting, error diagnostics, and autocomplete for NOUS (.nous) files",
  "version": "0.1.0",
  "publisher": "contrario",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contrario/nous"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:nous"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nous",
        "aliases": ["NOUS", "nous", "Νοῦς"],
        "extensions": [".nous"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nous-light.png",
          "dark": "./icons/nous-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "nous",
        "scopeName": "source.nous",
        "path": "./syntaxes/nous.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "NOUS",
      "properties": {
        "nous.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable NOUS Language Server for diagnostics and autocomplete"
        },
        "nous.lsp.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python interpreter with pygls installed"
        },
        "nous.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to nous_lsp.py server script"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
