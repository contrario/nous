# infra_monitor.nous — Infrastructure Monitor

world InfraMonitor {
    law CostCeiling = $0.05 per cycle
    heartbeat = 1m
}

message HealthReport {
    status: string
    source: string
}

soul Watcher {
    mind: gemini-flash @ Tier2
    senses: [check_positions]

    memory {
        check_count: int = 0
    }

    instinct {
        let status = sense check_positions()
        remember check_count += 1
    }

    heal {
        on timeout => retry(2, exponential)
    }
}
