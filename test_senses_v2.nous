world SensesV2Test {
    law cost_ceiling = $1.00 per cycle
    heartbeat = 60s
}

sense stock_price {
    description: "fetch current price of a crypto symbol"
    http_get: "https://api.binance.com/api/v3/ticker/price?symbol={symbol}"
    timeout: 10
    returns: json
    cache_ttl: 30
}

sense weather_now {
    description: "current weather for a city"
    http_get: "https://wttr.in/{city}?format=3"
    timeout: 8
    returns: string
    cache_ttl: 300
}

sense github_release {
    description: "latest release for a github repo"
    http_get: "https://api.github.com/repos/{owner}/{repo}/releases/latest"
    timeout: 15
    returns: json
    headers: %{Accept: "application/vnd.github+json"}
}

message PriceReport {
    symbol: string
    price: float
}

soul MarketSensor {
    mind: deepseek-chat @ Tier1
    senses: [stock_price, weather_now, github_release]
    memory {
        last_price: float = 0.0
        updates: int = 0
    }
    instinct {
        let data = sense stock_price(symbol: "BTCUSDT")
        remember updates = updates + 1
        speak PriceReport(symbol: "BTCUSDT", price: 0.0)
    }
}
