# topology_test.nous — Distributed deployment test
# Two servers: alpha runs Scout+Quant, beta runs Hunter+Monitor

world GateDistributed {
    law MaxCostPerCycle = $2.00 per cycle
    law RequireApproval = true
    heartbeat = 30s
    timezone = "UTC"
}

message Signal {
    pair: string
    rsi: float
    volume: float
}

message Decision {
    action: string
    pair: string
    confidence: float
    reason: string
}

message TradeOrder {
    action: string
    pair: string
    size: float
}

message StatusUpdate {
    source: string
    status: string
    detail: string
}

soul Scout {
    mind: deepseek-r1 @ Tier1
    senses: [fetch_rsi, gate_alpha_scan]

    memory {
        scan_count: int = 0
        last_pairs: [string] = []
    }

    instinct {
        let candidates = sense gate_alpha_scan()
        for token in candidates {
            let rsi = sense fetch_rsi(pair: token.pair)
            if rsi < 30 || rsi > 70 {
                speak Signal(pair: token.pair, rsi: rsi, volume: token.volume)
            }
        }
        remember scan_count = scan_count + 1
    }

    heal {
        on timeout => retry(3, exponential)
        on rate_limit => sleep 2 cycle
    }
}

soul Quant {
    mind: claude-haiku @ Tier2
    senses: [fetch_rsi]

    memory {
        decisions: int = 0
    }

    instinct {
        let signal = listen Scout::Signal
        let decision = if signal.rsi < 30 { "buy" } else { "sell" }
        speak Decision(action: decision, pair: signal.pair, confidence: 0.75, reason: "RSI signal")
        remember decisions = decisions + 1
    }

    heal {
        on timeout => retry(2, fixed)
    }
}

soul Hunter {
    mind: deepseek-r1 @ Tier1
    senses: [execute_trade]

    memory {
        trades: int = 0
    }

    instinct {
        let order = listen Quant::Decision
        if order.confidence > 0.6 {
            speak TradeOrder(action: order.action, pair: order.pair, size: 100.0)
            remember trades = trades + 1
        }
    }

    heal {
        on timeout => retry(1, fixed)
        on exchange_error => alert(telegram)
    }
}

soul Monitor {
    mind: deepseek-r1 @ Tier0A
    senses: [send_telegram]

    instinct {
        speak StatusUpdate(source: self, status: "alive", detail: "monitoring")
    }

    heal {
        on timeout => retry(2, fixed)
    }
}

nervous_system {
    Scout -> Quant -> Hunter
    Hunter -> Monitor
}

topology {
    alpha: "188.245.245.132" {
        souls: [Scout, Quant]
        port: 9100
        ssh_key: "~/.ssh/id_rsa"
        python: "python3"
    }
    beta: "10.0.0.2" {
        souls: [Hunter, Monitor]
        port: 9100
        ssh_user: "deploy"
        env_file: "/opt/aetherlang_agents/.env"
    }
}
