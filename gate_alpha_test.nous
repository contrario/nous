# gate_alpha_test.nous — Tests for Gate Alpha

world GateAlpha {
    law CostCeiling = $0.10 per cycle
    law MaxLatency = 30s
    law NoLiveTrading = true
    heartbeat = 5m
}

message Signal {
    pair: string
    score: float
    rsi: float?
    source: SoulRef
}

message Decision {
    action: string
    size: float
    risk: float
    sl_pct: float
    tp_pct: float
}

soul Scout {
    mind: deepseek-r1 @ Tier1
    senses: [gate_alpha_scan, fetch_rsi]
    memory {
        scan_count: int = 0
    }
    instinct {
        let tokens = sense gate_alpha_scan()
        remember scan_count += 1
    }
    dna {
        volume_threshold: 50000 ~ [10000, 200000]
        rsi_ceiling: 70 ~ [60, 80]
    }
    heal {
        on timeout => retry(2, exponential)
    }
}

soul Quant {
    mind: claude-haiku @ Tier0A
    senses: [calculate_kelly]
    memory {
        risk_score: float = 0.0
    }
    instinct {
        let signal = listen Scout::Signal
    }
    heal {
        on timeout => retry(3, exponential)
    }
}

nervous_system {
    Scout -> Quant
}

test "world configuration" {
    assert soul_count == 2
    assert message_count == 2
    assert law_CostCeiling == 0.10
    assert law_NoLiveTrading == true
}

test "scout soul structure" {
    assert soul_Scout_exists == true
    assert soul_Scout_model == "deepseek-r1"
    assert soul_Scout_tier == "Tier1"
    assert soul_Scout_sense_count == 2
    assert soul_Scout_gene_count == 2
    assert soul_Scout_dna_volume_threshold == 50000
    assert soul_Scout_dna_rsi_ceiling == 70
}

test "quant soul structure" {
    assert soul_Quant_exists == true
    assert soul_Quant_model == "claude-haiku"
    assert soul_Quant_tier == "Tier0A"
    assert soul_Quant_sense_count == 1
}

test "message schemas" {
    assert msg_Signal_exists == true
    assert msg_Signal_field_count == 4
    assert msg_Signal_has_pair == true
    assert msg_Signal_type_pair == "string"
    assert msg_Decision_field_count == 5
}

test "pipeline integrity" {
    assert validation_pass == true
    assert typecheck_pass == true
    assert route_count == 1
}

test "law constraints" {
    assert law_CostCeiling <= 1.0
    assert law_CostCeiling > 0.0
    assert law_MaxLatency == 30
}
