// nous.lark — EBNF Grammar for NOUS v2.0
// LALR Parser | The Living Language | Noosphere Project
// Author: Hlias Staurou (Hlia) + Claude

start: top_level+

top_level: world_decl
         | soul_decl
         | message_decl
         | nsp_decl
         | nervous_system_decl
         | evolution_decl
         | perception_decl
         | deploy_decl
         | topology_decl
         | noesis_decl
         | import_stmt
         | test_block

// ═══════════════════════════════════════════
// IMPORT
// ═══════════════════════════════════════════

import_stmt: IMPORT STRING    -> import_file
           | IMPORT NAME      -> import_package

// ═══════════════════════════════════════════
// NOESIS — Symbolic Intelligence
// ═══════════════════════════════════════════

noesis_decl: NOESIS "{" noesis_body* "}"
noesis_body: "lattice" ":" STRING            -> noesis_lattice
           | "oracle_threshold" ":" FLOAT    -> noesis_threshold
           | "auto_learn" ":" BOOL           -> noesis_auto_learn
           | "auto_evolve" ":" BOOL          -> noesis_auto_evolve
           | "gap_tracking" ":" BOOL         -> noesis_gap_tracking

// ═══════════════════════════════════════════
// WORLD
// ═══════════════════════════════════════════

world_decl: WORLD NAME "{" world_body* "}"
world_body: law_decl | heartbeat_decl | timezone_decl | telemetry_block | config_assign

law_decl: LAW NAME "=" law_expr
law_expr: currency_lit PER CYCLE          -> law_cost
        | currency_lit                    -> law_currency
        | CONSTITUTIONAL "(" INT ")"      -> law_constitutional
        | duration_lit                     -> law_duration
        | BOOL                            -> law_bool
        | INT                             -> law_int

heartbeat_decl: "heartbeat" "=" duration_lit
timezone_decl: "timezone" "=" STRING
config_assign: NAME "=" expr

// ═══════════════════════════════════════════
// SOUL
// ═══════════════════════════════════════════

soul_decl: SOUL NAME "{" soul_body* "}"
soul_body: mind_decl
         | senses_decl
         | memory_block
         | instinct_block
         | dna_block
         | heal_block
         | mitosis_block
         | immune_system_block
         | dream_system_block

mind_decl: "mind" ":" model_name "@" TIER
model_name: NAME ("-" model_part)*
model_part: INT NAME    -> model_int_name
          | NAME
          | INT

senses_decl: "senses" ":" "[" name_list "]"
name_list: NAME ("," NAME)*

// ── Memory ──
memory_block: MEMORY "{" field_decl* "}"
field_decl: NAME ":" type_expr ("=" expr)? ","?

// ── Instinct ──
instinct_block: INSTINCT "{" statement* "}"

statement: let_stmt
         | remember_assign
         | remember_accum
         | speak_stmt
         | listen_expr
         | guard_stmt
         | if_stmt
         | for_stmt
         | sleep_stmt
         | resonate_stmt
         | sense_bare
         | sense_bind
         | expr

let_stmt: "let" NAME "=" expr

remember_assign: REMEMBER NAME "=" expr
remember_accum: REMEMBER NAME "+=" expr

speak_stmt: SPEAK NAME "(" arg_list? ")"                          -> speak_local
          | SPEAK "@" NAME "::" NAME "(" arg_list? ")"            -> speak_cross

listen_expr: "let" NAME "=" LISTEN NAME "::" NAME                 -> listen_local
           | "let" NAME "=" LISTEN "@" NAME "::" NAME "::" NAME   -> listen_cross

guard_stmt: GUARD expr

if_stmt: "if" expr "{" statement* "}" ("else" "{" statement* "}")?
for_stmt: "for" NAME "in" expr "{" statement* "}"
sleep_stmt: SLEEP DURATION_VAL

resonate_stmt: "let" NAME "=" RESONATE STRING                                -> resonate_bind
             | "let" NAME "=" RESONATE STRING "with" NAME ">" FLOAT          -> resonate_bind_guarded
             | RESONATE STRING                                               -> resonate_bare
             | "let" NAME "=" RESONATE "(" expr ")"                          -> resonate_bind_dynamic
             | "let" NAME "=" RESONATE "(" expr ")" "with" NAME ">" FLOAT    -> resonate_bind_dynamic_guarded
             | RESONATE "(" expr ")"                                         -> resonate_bare_dynamic

sense_bare: SENSE NAME "(" arg_list? ")"
sense_bind: "let" NAME "=" SENSE NAME "(" arg_list? ")"

// ── DNA ──
dna_block: DNA "{" gene_decl* "}"
gene_decl: NAME ":" expr "~" "[" expr ("," expr)+ "]"

// ── Heal ──
heal_block: HEAL "{" heal_rule* "}"
heal_rule: "on" NAME "=>" heal_action ("then" heal_action)*
heal_action: "retry" "(" INT "," NAME ")"             -> heal_retry
           | "lower" "(" NAME "," expr ")"             -> heal_lower
           | "raise" "(" NAME "," expr ")"             -> heal_raise
           | "hibernate" "until" NAME                   -> heal_hibernate
           | "fallback" "(" NAME ")"                    -> heal_fallback
           | "delegate" "(" NAME ")"                    -> heal_delegate
           | "alert" "(" NAME ")"                       -> heal_alert
           | "sleep" DURATION_VAL                       -> heal_sleep
           | "retry"                                    -> heal_retry_simple



// ── Dream System — Speculative Pre-computation ──
dream_system_block: DREAM_SYSTEM "{" dream_field* "}"
dream_field: "enabled" ":" BOOL                      -> dream_enabled
           | "trigger_idle_sec" ":" INT              -> dream_idle_sec
           | "dream_mind" ":" model_name "@" TIER    -> dream_mind
           | "max_cache" ":" INT                     -> dream_max_cache
           | "speculation_depth" ":" INT             -> dream_depth

// ── Immune System — Adaptive Recovery ──
immune_system_block: IMMUNE_SYSTEM "{" immune_field* "}"
immune_field: "adaptive_recovery" ":" BOOL        -> immune_adaptive
            | "share_with_clones" ":" BOOL        -> immune_share
            | "antibody_lifespan" ":" duration_lit -> immune_lifespan

// ── Mitosis — Self-Replication ──

// ═══════════════════════════════════════════
// TELEMETRY — τηλεμετρία
// ═══════════════════════════════════════════

telemetry_block: TELEMETRY "{" telemetry_field* "}"
telemetry_field: "enabled" ":" BOOL                -> telemetry_enabled
               | "exporter" ":" NAME               -> telemetry_exporter
               | "endpoint" ":" STRING             -> telemetry_endpoint
               | "sample_rate" ":" (FLOAT | INT)   -> telemetry_sample_rate
               | "trace_senses" ":" BOOL           -> telemetry_trace_senses
               | "trace_llm" ":" BOOL              -> telemetry_trace_llm
               | "buffer_size" ":" INT             -> telemetry_buffer_size

mitosis_block: MITOSIS "{" mitosis_field* "}"
mitosis_field: "trigger" ":" expr              -> mitosis_trigger
             | "max_clones" ":" INT            -> mitosis_max_clones
             | "cooldown" ":" duration_lit     -> mitosis_cooldown
             | "clone_tier" ":" TIER           -> mitosis_clone_tier
             | "verify" ":" BOOL              -> mitosis_verify
             | "retire_trigger" ":" expr       -> mitosis_retire_trigger
             | "retire_cooldown" ":" duration_lit -> mitosis_retire_cooldown
             | "min_clones" ":" INT            -> mitosis_min_clones



// ═══════════════════════════════════════════
// TEST
// ═══════════════════════════════════════════

test_block: TEST STRING "{" test_stmt* "}"
test_stmt: "assert" expr                   -> test_assert
         | "setup" "{" statement* "}"      -> test_setup

// ═══════════════════════════════════════════
// MESSAGE
// ═══════════════════════════════════════════

message_decl: MESSAGE NAME "{" message_field* "}"
message_field: NAME ":" type_expr ("=" expr)?

// ═══════════════════════════════════════════
// NSP
// ═══════════════════════════════════════════

nsp_decl: "nsp" "{" nsp_field* "}"
nsp_field: NAME ":" type_expr

// ═══════════════════════════════════════════
// NERVOUS SYSTEM
// ═══════════════════════════════════════════

nervous_system_decl: NERVOUS_SYSTEM "{" nerve_stmt* "}"
nerve_stmt: route_stmt
          | match_route
          | fanin_stmt
          | fanout_stmt
          | feedback_stmt

route_stmt: NAME "->" NAME                        -> route_linear
          | NAME "->" NAME "->" NAME              -> route_chain3

match_route: NAME "->" "match" "{" match_arm+ "}"
match_arm: expr "=>" NAME ","?                    -> match_arm_soul
         | "_" "=>" SILENCE ","?                  -> match_arm_silence

fanin_stmt: "[" name_list "]" "->" NAME
fanout_stmt: NAME "->" "[" name_list "]"
feedback_stmt: NAME "::" NAME "->" NAME "::" dotted_name

// ═══════════════════════════════════════════
// EVOLUTION
// ═══════════════════════════════════════════

evolution_decl: EVOLUTION "{" evolution_body* "}"
evolution_body: "schedule" ":" time_lit
              | "fitness" ":" expr
              | mutate_block

mutate_block: "mutate" dotted_name "{" mutate_body* "}"
mutate_body: "strategy" ":" NAME "(" arg_list ")"       -> mutate_strategy
           | "survive_if" ":" expr                       -> mutate_survive
           | "rollback_if" ":" expr                      -> mutate_rollback

// ═══════════════════════════════════════════
// PERCEPTION
// ═══════════════════════════════════════════

perception_decl: PERCEPTION "{" perception_rule* "}"
perception_rule: "on" perception_trigger "=>" perception_action

perception_trigger: NAME "(" STRING ")"                  -> trigger_named
                  | NAME "(" STRING "," expr ")"         -> trigger_named_expr
                  | NAME                                 -> trigger_simple

perception_action: WAKE_ALL                             -> action_wake_all
                 | "wake" NAME                           -> action_wake
                 | "broadcast" NAME                      -> action_broadcast
                 | "alert" NAME                          -> action_alert

// ═══════════════════════════════════════════
// DEPLOY & TOPOLOGY
// ═══════════════════════════════════════════

deploy_decl: "deploy" NAME "{" deploy_body* "}"
deploy_body: NAME ":" expr

topology_decl: "topology" "{" topo_server* "}"
topo_server: NAME ":" STRING "{" topo_body* "}"
topo_body: NAME ":" expr

// ═══════════════════════════════════════════
// EXPRESSIONS
// ═══════════════════════════════════════════

?expr: or_expr

?or_expr: and_expr ("||" and_expr)*
?and_expr: compare_expr ("&&" compare_expr)*
?compare_expr: add_expr (COMP_OP add_expr)*
?add_expr: mul_expr (ADD_OP mul_expr)*
?mul_expr: unary_expr (MUL_OP unary_expr)*

ADD_OP: "+" | "-"
MUL_OP: "*" | "/" | "%"
?unary_expr: "!" unary_expr    -> not_expr
           | call_expr

?call_expr: call_expr "." NAME "(" arg_list? ")"  -> method_call
          | call_expr "." NAME                     -> attr_access
          | call_expr "(" arg_list? ")"            -> func_call
          | atom

?atom: FLOAT                                       -> float_lit
     | INT                                         -> int_lit
     | STRING                                      -> string_lit
     | BOOL                                        -> bool_lit
     | currency_lit
     | duration_lit
     | "now" "(" ")"                               -> now_lit
     | "self"                                      -> self_ref
     | "world" "." dotted_name                     -> world_ref
     | NAME "::" NAME                              -> soul_field_ref
     | NAME                                        -> name_ref
     | "[" expr_list? "]"                          -> list_lit
     | "%{" kv_list? "}"                           -> map_lit
     | inline_if
     | "(" expr ")"

inline_if: "if" expr "{" expr "}" "else" "{" expr "}"

arg_list: arg ("," arg)*
arg: NAME ":" expr                                 -> named_arg
   | expr                                          -> positional_arg
kv_list: kv_pair ("," kv_pair)*
kv_pair: NAME ":" expr
expr_list: expr ("," expr)*

// ═══════════════════════════════════════════
// TYPES
// ═══════════════════════════════════════════

?type_expr: "[" type_expr "]"                      -> list_type
          | "{" type_expr ":" type_expr "}"         -> map_type
          | type_expr "?"                           -> optional_type
          | NAME                                    -> named_type

// ═══════════════════════════════════════════
// REFERENCES
// ═══════════════════════════════════════════

dotted_name: NAME ("." NAME)+

// ═══════════════════════════════════════════
// LITERALS
// ═══════════════════════════════════════════

currency_lit: "$" FLOAT  -> currency_usd
            | "$" INT    -> currency_usd
            | "€" FLOAT  -> currency_eur
            | "€" INT    -> currency_eur

duration_lit: DURATION_VAL

time_lit: INT ":" INT NAME    -> time_hm

// ═══════════════════════════════════════════
// KEYWORDS (English + Greek bilingual) — .2 priority beats NAME
// ═══════════════════════════════════════════

WORLD.2: "world" | "κόσμος"
SOUL.2: "soul" | "ψυχή"
MEMORY.2: "memory" | "μνήμη"
INSTINCT.2: "instinct" | "ένστικτο"
NOESIS.2: "noesis" | "νόηση"
RESONATE.2: "resonate" | "αντήχηση"
IMPORT.2: "import" | "εισαγωγή"
TEST.2: "test" | "δοκιμή"
SENSE.2: "sense" | "αίσθηση"
REMEMBER.2: "remember" | "θυμάμαι"
SPEAK.2: "speak" | "λέω"
LISTEN.2: "listen" | "ακούω"
DNA.2: "dna" | "DNA"
HEAL.2: "heal" | "θεραπεία"
TELEMETRY.2: "telemetry" | "τηλεμετρία"
MITOSIS.2: "mitosis" | "μίτωση"
IMMUNE_SYSTEM.2: "immune_system" | "ανοσία"
DREAM_SYSTEM.2: "dream_system" | "ονειρεύομαι"
LAW.2: "law" | "νόμος"
GUARD.2: "guard" | "φύλακας"
SLEEP.2: "sleep" | "ύπνος"
NERVOUS_SYSTEM.2: "nervous_system" | "νευρικό"
EVOLUTION.2: "evolution" | "εξέλιξη"
PERCEPTION.2: "perception" | "αντίληψη"
MESSAGE.2: "message" | "μήνυμα"
SILENCE.2: "silence" | "σιωπή"
WAKE_ALL.2: "wake_all"
CONSTITUTIONAL.2: "constitutional"
PER.2: "per"
CYCLE.2: "cycle"
TIER: /Tier[0-3][A-B]?|Groq|Together|Fireworks|Cerebras/

// ═══════════════════════════════════════════
// PRIMITIVES
// ═══════════════════════════════════════════

BOOL.2: "true" | "false"
COMP_OP: "==" | "!=" | ">=" | "<=" | ">" | "<"

DURATION_VAL.3: /\d+(ms|s|m|h|d)(?![a-zA-Z_])/

NAME: /[a-zA-Z_\u0370-\u03FF][a-zA-Z0-9_\u0370-\u03FF]*/
FLOAT: /\d+\.\d+/
INT: /\d+/
STRING: /\"[^\"]*\"/

// ═══════════════════════════════════════════
// WHITESPACE & COMMENTS
// ═══════════════════════════════════════════

COMMENT: /#[^\n]*/
%ignore COMMENT
%ignore /[\s]+/
